{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sec-issue-collection/schema/policy.schema.json",
  "title": "政策监管动态记录(文档型)",
  "type": "object",
  "required": ["doc_id", "title", "issuer", "doc_type", "status", "published_date", "sources"],
  "properties": {
    "doc_id": {"type": "string"},
    "title": {"type": "string"},
    "issuer": {"type": "string", "description": "发布机关"},
    "doc_number": {"type": "string", "description": "文号/标准号(去重键)"},
    "doc_type": {"enum": ["法律", "行政法规", "部门规章", "规范性文件", "国家标准", "行业标准", "征求意见稿", "监管通知", "其他"]},
    "status": {"enum": ["征求意见", "发布", "生效", "修订", "废止"]},
    "published_date": {"type": "string", "format": "date"},
    "effective_date": {"type": ["string", "null"], "format": "date"},
    "topics": {"type": "array", "items": {"type": "string"}},
    "affected_industries": {"type": "array", "items": {"type": "string"}},
    "related_products": {"type": "array", "items": {"type": "string"}, "description": "对应可售合规产品"},
    "summary": {"type": "string"},
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ref_id", "url_or_doc_number", "publisher", "published_date", "credibility"],
        "properties": {
          "ref_id": {"type": "string"},
          "url_or_doc_number": {"type": "string"},
          "title": {"type": "string"},
          "publisher": {"type": "string"},
          "published_date": {"type": "string", "format": "date"},
          "credibility": {"enum": ["S1", "S2", "S3", "S4"]},
          "snapshot_id": {"type": "string"}
        }
      }
    },
    "status_field": {"type": "string"}
  }
}
