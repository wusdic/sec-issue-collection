# 复制为 .env 后按需修改

# 数据库(留空用 SQLite 开发库;生产用 PostgreSQL)
DATABASE_URL=postgresql+psycopg2://sec:sec@postgres:5432/sec_collection

# LLM(离线/测试用 mock;生产用 OpenAI 兼容接口,国内可接 Qwen/DeepSeek)
# CLI 与 API 都会自动读取本 .env 文件(无需再手动 set 环境变量)
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_SCREEN_MODEL=
# Embedding 独立配置(很多聊天模型不支持向量接口,需分开配)
# 例:阿里云百炼 LLM_EMBED_MODEL=text-embedding-v3;留空则回退聊天模型/接口
LLM_EMBED_BASE_URL=
LLM_EMBED_API_KEY=
LLM_EMBED_MODEL=

# 存档
ARCHIVE_ROOT=/app/data/archive
PLAYWRIGHT_ENABLED=0

# 鉴权(生产务必修改)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=12

# Celery
REDIS_URL=redis://redis:6379/0

# 抓取礼仪
CRAWL_DELAY_SECONDS=2
